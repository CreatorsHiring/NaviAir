<%layout("/layouts/boilerplate")%>
<body>
<div class="show-page-card">
    <div class="card" style="width: 18rem;">
    <img src="<%=listing.image%>" class="card-img-top" alt="image">
    <div class="card-body">
        <h5 class="card-title"><%=listing.title%></h5>
        <p class="card-text"><%=listing.description%></p>
    </div>
    <ul class="list-group list-group-flush">
        <li class="list-group-item">Price: <%=listing.price.toLocaleString("en-IN")%></li>
        <li class="list-group-item">Location: <%=listing.location%></li>
        <li class="list-group-item">Country: <%=listing.country%></li>
    </ul>
        <div class="card-body card-body-btns">
            <a href="/listings/<%=listing._id%>/edit" class="card-link btn btn-primary show-edit-btn">Edit</a>
            <form method ="POST" action="/listings/<%=listing._id%>?_method=DELETE">
                <button class="card-link btn btn-danger show-delete-btn">Delete</button>
            </form>
        </div>
    </div>
</div>
